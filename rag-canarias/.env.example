# Rate limiting
FETCH_DELAY_SECONDS=1.0
FETCH_MAX_RETRIES=3
FETCH_TIMEOUT_SECONDS=30

# User agent
USER_AGENT=RAG-Canarias-TFG/1.0 (Trabajo Fin de Grado)

# Paths
DATA_DIR=data
DB_PATH=data/rag_canarias.db
RAW_QUEUE_PATH=data/raw_queue.jsonl

# Chunking
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Qdrant (docker compose)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=canarias_patrimonio

# Embeddings — Phase 1 (sentence-transformers, MPS en M4 Pro)
EMBEDDING_MODEL=BAAI/bge-m3

# LLM local — Phase 2 (Ollama nativo macOS, con Metal)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b-instruct-q4_K_M

# Anthropic — Phase 2 opcional (Claude Sonnet para evaluación de techo)
ANTHROPIC_API_KEY=

# Logging
LOG_LEVEL=INFO
